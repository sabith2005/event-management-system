@model List<KMCEventWeb.Models.EventVM>

@{
    ViewData["Title"] = "Event List";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f7fa;
        color: #222;
    }

    .page-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 20px;
    }

    .page-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .page-header h2 {
            color: #2A6F97;
            font-size: 32px;
            margin-bottom: 10px;
        }

    .message-box {
        background: #eaf7ed;
        border: 1px solid #b7e4c7;
        color: #1f7a36;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .search-form {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        flex: 1;
    }

    .search-input {
        flex: 1;
        min-width: 250px;
        padding: 12px 14px;
        border: 1px solid #cfd8df;
        border-radius: 10px;
        font-size: 15px;
    }

        .search-input:focus {
            border-color: #4EA1D3;
            outline: none;
            box-shadow: 0 0 0 3px rgba(78, 161, 211, 0.16);
        }

    .btn {
        border: none;
        border-radius: 10px;
        padding: 12px 18px;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        display: inline-block;
        transition: 0.3s ease;
    }

    .btn-search {
        background: #2A6F97;
        color: #fff;
    }

    .btn-clear {
        background: #6c757d;
        color: #fff;
    }

    .btn-register {
        background: #28A745;
        color: #fff;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn:hover,
        .btn-register:hover {
            opacity: 0.92;
        }

    .record-count {
        font-weight: 600;
        color: #2A6F97;
        margin-bottom: 20px;
    }

    .event-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .event-card {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
        padding: 22px;
        border-top: 6px solid #2A6F97;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .event-title {
        font-size: 22px;
        font-weight: 700;
        color: #2A6F97;
        margin-bottom: 8px;
    }

    .event-id {
        font-size: 13px;
        color: #666;
        margin-bottom: 14px;
    }

    .event-description {
        color: #444;
        line-height: 1.6;
        margin-bottom: 16px;
        min-height: 70px;
    }

    .event-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 18px;
    }

    .detail-box {
        background: #f8fbfd;
        border: 1px solid #e0ebf1;
        border-radius: 10px;
        padding: 10px 12px;
    }

    .detail-label {
        font-size: 12px;
        color: #666;
        margin-bottom: 4px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .detail-value {
        font-size: 14px;
        font-weight: 600;
        color: #222;
    }

    .status-badge {
        display: inline-block;
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .status-active {
        background: #eaf7ed;
        color: #1f7a36;
    }

    .status-inactive {
        background: #fbeaea;
        color: #b42318;
    }

    .closed-text {
        font-weight: 700;
        color: #b42318;
    }

    .no-events {
        text-align: center;
        background: #fff;
        border-radius: 16px;
        padding: 35px 20px;
        color: #b42318;
        font-weight: 700;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.06);
    }

    @@media (max-width: 768px) {
        .page-container {
            margin: 20px auto;
            padding: 14px;
        }

        .page-header h2 {
            font-size: 26px;
        }

        .event-details {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <h2>Available Events</h2>
    </div>

    @if (TempData["msg"] != null)
    {
        <div class="message-box">
            @TempData["msg"]
        </div>
    }

    <div class="top-bar">
        <form method="get" asp-action="Index" class="search-form">
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   placeholder="Search by Event Name..."
                   class="search-input" />

            <button type="submit" class="btn btn-search">Search</button>
            <a asp-action="Index" class="btn btn-clear">Clear</a>
        </form>
    </div>

    <p class="record-count">Total Records: @(Model != null ? Model.Count : 0)</p>

    @if (Model != null && Model.Count > 0)
    {
        <div class="event-grid">
            @foreach (var item in Model)
            {
                <div class="event-card">
                    <div>
                        <div class="event-title">@item.Title</div>
                        <div class="event-id">Event ID: @item.EventId</div>

                        <div class="event-description">
                            @item.Description
                        </div>

                        @if (item.IsActive)
                        {
                            <span class="status-badge status-active">Active</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Inactive</span>
                        }

                        <div class="event-details">
                            <div class="detail-box">
                                <div class="detail-label">Type</div>
                                <div class="detail-value">@item.EventType</div>
                            </div>

                            <div class="detail-box">
                                <div class="detail-label">Venue</div>
                                <div class="detail-value">@item.Venue</div>
                            </div>

                            <div class="detail-box">
                                <div class="detail-label">Date</div>
                                <div class="detail-value">@item.EventDate.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>

                            <div class="detail-box">
                                <div class="detail-label">Capacity</div>
                                <div class="detail-value">@item.Capacity</div>
                            </div>
                        </div>
                    </div>

                    <div>
                        @if (item.IsActive)
                        {
                            <a asp-action="Register" asp-route-id="@item.EventId" class="btn-register">Register</a>
                        }
                        else
                        {
                            <span class="closed-text">Closed</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-events">
            No events found
        </div>
    }
</div>