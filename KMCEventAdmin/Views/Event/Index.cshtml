@model KMCEventAdmin.Models.EventVM

@{
    ViewData["Title"] = "Manage Event";
}

<h1>Manage Event</h1>

@if (TempData["msg"] != null)
{
    <p>@TempData["msg"]</p>
}

<form method="post">
    <table>
        <tr>
            <td><label>Event ID</label></td>
            <td><input asp-for="eventId" /></td>
        </tr>
        
        <tr>
            <td><label>Description</label></td>
            <td><textarea asp-for="Description" rows="5" cols="45"></textarea></td>
        </tr>
        <tr>
            <td><label>Event Type</label></td>
            <td><input asp-for="EventType" /></td>
        </tr>
       
        <tr>
            <td><label>Event Date</label></td>
            <td><input asp-for="EventDate" /></td>
        </tr>
        <tr>
            <td><label>Capacity</label></td>
            <td><input asp-for="Capacity" /></td>
        </tr>
        <tr>
            <td><label>Is Active</label></td>
            <td><input asp-for="IsActive" type="checkbox" /></td>
        </tr>
        <tr>
            <td><label>Organizer ID</label></td>
            <td><input asp-for="OrganizerId" /></td>
        </tr>
        <tr>
            <td></td>
            <td>
                <button type="submit" formaction="/ManageEvent/AddNew">Add New</button>
                <button type="submit" formaction="/ManageEvent/Update">Update</button>
                <button type="submit" formaction="/ManageEvent/Delete">Delete</button>
                <a href="/ManageEvent/Index">Back</a>
            </td>
        </tr>
    </table>
</form>